{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "user-stories",
  "type": "object",
  "required": ["stories"],
  "properties": {
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "modules", "prose", "code"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "modules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "prose": {
            "type": "object",
            "required": ["actor", "precondition", "trigger", "expected"],
            "properties": {
              "actor": { "type": "string", "minLength": 1 },
              "precondition": { "type": "string", "minLength": 1 },
              "trigger": { "type": "string", "minLength": 1 },
              "expected": { "type": "string", "minLength": 1 }
            }
          },
          "code": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}
