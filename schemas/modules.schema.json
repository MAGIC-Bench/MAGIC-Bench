{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "modules",
  "type": "object",
  "required": ["modules"],
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "user_value"],
        "properties": {
          "id": { "type": "string", "pattern": "^M[0-9]+$" },
          "name": { "type": "string" },
          "user_value": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
