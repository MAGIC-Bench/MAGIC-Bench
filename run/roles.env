# 节点角色表 —— 在 netnode 上由 coordinator.sh 读取,用于 --launch-all SSH 拉起各节点 worker。
# 填真实 hostname(可在各节点 `hostname` 查)。netnode 自己不入列(它只做总控,且是唯一集群出口,不能清零)。
#
# 设计规模(测试期):5 出卷 + 15 考试(5类×3) + 判卷复用出卷节点(有 golden)。
# 现状:5类 agent 只有 codex 已登录;claude/kimi 装了待登录;cursor/antigravity 待装。先用 codex 跑通框架。

# 出卷节点(有 golden,跑 stage0-8 出题 + publish)。用内网 pod IP(免跳板免密,需各节点先 node_init 开 sshd)。
# 映射: node1=10.42.1.193(控制器) node2=.195 node3=.201 node4=.197 node5=.198 ; netnode=.194(不入列)
CHUTI_NODES="10.42.1.193 10.42.1.195 10.42.1.201 10.42.1.197 10.42.1.198"

# 考试节点(每类 3 个;只有 codex 现在能真跑)
EXAM_NODES_codex="yangh559-node6 yangh559-node7 yangh559-node8"
EXAM_NODES_claude=""        # 待 claude 登录后填 3 个
EXAM_NODES_kimi=""          # 待 kimi 登录后填 3 个
EXAM_NODES_cursor=""        # 待 cursor 安装登录后填 3 个
EXAM_NODES_antigravity=""   # 待 antigravity 解决墙+无头后填 3 个

# 判卷节点(必须有 golden;默认复用出卷节点)
GRADE_NODES="$CHUTI_NODES"
